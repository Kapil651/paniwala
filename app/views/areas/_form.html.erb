<%= form_with model: area, local: true, class: "card shadow p-4" do |form| %>
  <div class="mb-3">
    <%= form.label :name, "Area Name", class: "form-label fw-bold" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Enter area name", required: true %>
  </div>

  <div class="text-end">
    <%= form.submit area.new_record? ? "Create Area" : "Update Area", class: "btn btn-primary" %>
  </div>
<% end %>
