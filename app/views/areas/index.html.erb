<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="fw-bold">Areas</h2>
  <%= link_to "Create Area", new_area_path, class: "btn btn-success" %>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @areas.each do |area| %>
        <tr>
          <td>🔹 <%= area.name %></td>
          <td class="text-center">
            <div class="d-flex justify-content-center gap-2">
              <%= link_to "Edit", edit_area_path(area), class: "btn btn-primary btn-sm" %>
              <%= button_to "Delete", area, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
