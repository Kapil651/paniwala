<div class="container mt-4">
  <!-- Create Booking Button -->
  <div class="d-flex justify-content-end mb-3">
    <%= link_to "Create Booking", new_booking_path, class: "btn btn-success" %>
  </div>

  <!-- Bookings Table -->
  <div class="card shadow p-4">
    <h2 class="text-center mb-3">Bookings</h2>

    <%= search_form_for @q do |f| %>
      <div class="form-row mb-3">
        <div class="col">
          <%= f.label :given_gteq, 'Min Given' %>
          <%= f.number_field :given_gteq, class: 'form-control' %>
        </div>
        <div class="col">
          <%= f.label :given_lteq, 'Max Given' %>
          <%= f.number_field :given_lteq, class: 'form-control' %>
        </div>
        <div class="col">
          <%= f.label :receive_gteq, 'Min Received' %>
          <%= f.number_field :receive_gteq, class: 'form-control' %>
        </div>
        <div class="col">
          <%= f.label :receive_lteq, 'Max Received' %>
          <%= f.number_field :receive_lteq, class: 'form-control' %>
        </div>
        <div class="col-auto">
          <%= f.submit 'Search', class: 'btn btn-primary' %>
        </div>
      </div>
    <% end %>

    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>Name</th>
          <th>Given</th>
          <th>Received</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @bookings.each do |booking| %>
          <tr>
            <td> &bull; <%= booking.customer.name %> </td>
            <td><%= booking.given %></td>
            <td><%= booking.receive %></td>
            <td>
              <%= link_to 'Edit', edit_booking_path(booking), class: 'btn btn-primary btn-sm' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="mt-3">
      <%= paginate @bookings %>
    </div>
  </div>
</div>
