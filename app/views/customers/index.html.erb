<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="fw-bold">Customers</h2>
  <%= link_to "➕ Create Customer", new_customer_path, class: "btn btn-success" %>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Address</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @customers.each do |customer| %>
        <tr>
          <td>👤 <%= customer.name %></td>
          <td>📧 <%= customer.email %></td>
          <td>🏠 <%= customer.address %></td>
          <td class="text-center">
            <div class="d-flex justify-content-center gap-2">
              <%= link_to "✏️ Edit", edit_customer_path(customer), class: "btn btn-primary btn-sm" %>
              <%= button_to "🗑️ Delete", customer, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
