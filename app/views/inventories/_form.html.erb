<%= form_with model: inventory, local: true, class: "card shadow p-4" do |form| %>
  <h3 class="fw-bold text-primary mb-3">
    <%= inventory.new_record? ? "Add New Inventory" : "Edit Inventory" %>
  </h3>

  <div class="mb-3">
    <%= form.label :name, "Inventory Name", class: "form-label fw-bold" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Enter inventory name", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :count, "Quantity", class: "form-label fw-bold" %>
    <%= form.number_field :count, class: "form-control", placeholder: "Enter quantity", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :price, "Price", class: "form-label fw-bold" %>
    <%= form.number_field :price, class: "form-control", placeholder: "Enter price", required: true, step: "0.01" %>
  </div>

  <div class="text-end">
    <%= form.submit inventory.new_record? ? "Create Inventory" : "Update Inventory", class: "btn btn-primary px-4" %>
  </div>
<% end %>
