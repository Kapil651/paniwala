<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="fw-bold">Inventory</h2>
  <%= link_to "➕ Create Inventory", new_inventory_path, class: "btn btn-success" %>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Count</th>
        <th>Price</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @inventories.each do |inventory| %>
        <tr>
          <td>📦 <%= inventory.name %></td>
          <td>🔢 <%= inventory.count %></td>
          <td>💰 <%= number_to_currency(inventory.price) %></td>
          <td class="text-center">
            <div class="d-flex justify-content-center gap-2">
              <%= link_to "✏️ Edit", edit_inventory_path(inventory), class: "btn btn-primary btn-sm" %>
              <%= button_to "🗑️ Delete", inventory, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
