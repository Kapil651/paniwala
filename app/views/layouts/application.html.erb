<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Paaniwala" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>

   <% if supplier_signed_in? %> 
    <nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold" href="<%= root_path %>">Paaniwala</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <%= link_to "My Inventory", inventories_path, class: "nav-link btn btn-light mx-2" %>
            </li>
            <li class="nav-item">
              <%= link_to "My Customers", customers_path, class: "nav-link btn btn-light mx-2" %>
            </li>
            <li class="nav-item">
              <%= link_to "My Area", areas_path, class: "nav-link btn btn-light mx-2" %>
            </li>
            <li class="nav-item">
              <%= link_to "Booking", bookings_path, class: "nav-link btn btn-light mx-2" %>
            </li>
            <li class="nav-item">
              <%= link_to "Reports", reports_prepare_path, class: "nav-link btn btn-light mx-2" %>
            </li>

            <!-- Profile Section -->

             <li class="nav-item">
              <%= link_to edit_supplier_registration_path do %>
            <% if @supplier.image.present? %>

          <%= image_tag @supplier.image.url || "https://cdn.pixabay.com/photo/2017/02/23/13/05/avatar-2092113_1280.png", class: 'rounded-profile', alt: 'Profile Image' if @supplier.image? %>
  <% end %>
    <% end %>
            </li>
            
            <li class="nav-item">
            <%= button_to "Sign Out", destroy_supplier_session_path, method: :delete, class: "btn btn-danger mx-2" %>
            </li>
          </ul>
        </div>
      </div>
    </nav>

  <% else %>
    <div class="container text-center mt-4">
      <%= link_to "Sign in", new_supplier_session_path, class: "btn btn-primary" %> 
    </div>
  <% end %>   

  <div class="container mt-4">
    <%= yield %>
  </div>

  </body>
</html>
