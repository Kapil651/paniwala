<% if @bookings.any? %>
  <div class="card shadow p-4 mb-4">
    <h3 class="fw-bold text-primary mb-3">📊 Booking Report</h3>

    <div class="table-responsive">
      <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark text-center">
          <tr>
            <th>ID</th>
            <th>Customer</th>
            <th>Inventory</th>
            <th>Given Jars</th>
            <th>Received Jars</th>
            <th>Payment (₹)</th>
            <th>Booking Date</th>
          </tr>
        </thead>
        <tbody>
          <% total_given = 0 %>
          <% total_received = 0 %>
          <% total_payment = 0 %>

          <% @bookings.each do |booking| %>
            <% total_given += booking.given %>
            <% total_received += booking.receive %>
            <% total_payment += booking.given * booking.inventory.price %> 

            <tr class="text-center">
              <td><%= booking.id %></td>
              <td><%= booking.customer.name %></td>
              <td><%= booking.inventory.name %></td>
              <td><%= booking.given %></td>
              <td><%= booking.receive %></td>
              <td><strong><%= booking.calculate_total_price(booking.inventory) %> ₹</strong></td>
              <td><%= booking.created_at.strftime("%d-%m-%Y") %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="table-light">
          <tr class="fw-bold text-center">
            <th colspan="3">Total</th>
            <td><%= total_given %></td>
            <td><%= total_received %></td>
            <td><%= total_payment %> ₹</td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <div class="card shadow p-4">
    <h4 class="fw-bold text-success">🏆 Top 5 Customers</h4>

    <% if @top_bookings.any? %>
      <div class="table-responsive">
        <table class="table table-bordered table-striped table-hover">
          <thead class="table-dark text-center">
            <tr>
              <th>Customer</th>
              <th>Total Payment (₹)</th>
            </tr>
          </thead>
          <tbody>
            <% @top_bookings.each do |top_booking| %>
              <tr class="text-center">
                <td><%= top_booking.customer.name %></td>
                <td><strong><%= top_booking.calculate_total_price(top_booking.inventory) %> ₹</strong></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>

<% else %>
  <div class="alert alert-warning text-center mt-4">
    🚫 No bookings found for the selected period.
  </div>
<% end %>
