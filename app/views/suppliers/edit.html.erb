<div class="container mt-4">
  <div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
      <h2 class="mb-0">Edit Profile</h2>
    </div>
    <div class="card-body">
      
      <% if @supplier.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@supplier.errors.count, "error") %> prevented this from saving:</h4>
          <ul>
            <% @supplier.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_for @supplier, url: suppliers_edit_path(@supplier), method: :patch, html: { multipart: true } do |f| %>
    <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :name, class: "form-label" %>
            <%= f.text_field :name, class: "form-control", placeholder: "Enter your name" %>
          </div>

          <div class="col-md-6 mb-3">
            <%= f.label :company_name, class: "form-label" %>
            <%= f.text_field :company_name, class: "form-control", placeholder: "Enter company name" %>
          </div>

          <div class="col-md-6 mb-3">
            <%= f.label :address, class: "form-label" %>
            <%= f.text_field :address, class: "form-control", placeholder: "Enter address" %>
          </div>

          <div class="col-md-6 mb-3">
            <%= f.label :mobile, class: "form-label" %>
            <%= f.number_field :mobile, class: "form-control", placeholder: "Enter mobile number" %>
          </div>
        </div>
        <div class="col-md-6 mb-3">
  <%= f.label :image, "Profile Image", class: "form-label" %>
  <%= f.file_field :image, class: "form-control" %>
  
  <% if @supplier.image.present? %>
    <div class="mt-2">
      <strong>Current Image:</strong><br>
      <%= image_tag @supplier.image.url, class: "img-thumbnail", width: "150" %>
    </div>
  <% end %>
</div>


        <div class="d-grid">
          <%= f.submit "Update Profile", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>
      
    </div>
  </div>
</div>
